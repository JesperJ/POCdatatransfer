# Copy to .env and fill in values. NEVER commit .env to git.

# Azure DevOps organisation URL — e.g. https://dev.azure.com/your-org
AZP_URL=https://dev.azure.com/your-org

# Personal Access Token with scope: Agent Pools (Read & Manage)
# Generate at: Azure DevOps → User Settings → Personal Access Tokens
AZP_TOKEN=your-pat-token

# Agent pool name (create it in Azure DevOps → Project Settings → Agent pools)
AZP_POOL=self-hosted-prod

# Unique name for this agent — use the hostname so it's identifiable
AZP_AGENT_NAME=prod-server-01
